RETURN p,
       collect(DISTINCT {
         reaction_id: r.name,
         active_sites: collect(DISTINCT site.name),
         catalysts: collect(DISTINCT z.name),
         reaction_properties: collect(DISTINCT prop.name),
         reactants: collect(DISTINCT reactant.name),
         products: collect(DISTINCT product.name)
