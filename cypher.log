OPTIONAL MATCH (site:activeSite)-[:LINKS]->(r)
OPTIONAL MATCH (z:zeolite)-[:LINKS]->(site)
WITH p, r, collect(DISTINCT prop) AS reactionProps, collect(DISTINCT site) AS activeSites, collect(DISTINCT z) AS catalysts
RETURN p, collect(DISTINCT {reactionName: r.name, properties: [p IN reactionProps | p.name], activeSites: [s IN activeSites | s.name], catalysts: [z IN catalysts | z.name]}) AS stepDetails
LIMIT 100
